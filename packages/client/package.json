{
  "name": "@dfsync/client",
  "version": "0.2.0",
  "description": "Reliable service-to-service HTTP communication toolkit for Node.js and TypeScript",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "sideEffects": false,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dfsyncjs/dfsync.git",
    "directory": "packages/client"
  },
  "homepage": "https://dfsyncjs.github.io",
  "bugs": {
    "url": "https://github.com/dfsyncjs/dfsync/issues"
  },
  "keywords": [
    "typescript",
    "nodejs",
    "http-client",
    "microservices",
    "backend",
    "service-to-service",
    "api-client"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist coverage",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "lint": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@vitest/coverage-v8": "^3.0.8",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vitest": "^3.0.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
